     1                                  ; Free86/ testINTr - real mode interrupt tests
     2                                  ; - run various INTR/ NMI tests
     3                                  ; - output test number on port 0x2a
     4                                  ;
     5                                  ; - load image at segment 0xf000
     6                                  ;
     7                                  ; compile:
     8                                  ;   nasm -f bin testINTr.asm -l testINTr.lst -o testINTr.bin
     9                                  
    10                                  C_SEG_REAL equ 0xf000
    11                                  DEBUG_PORT equ 0x2a
    12                                  
    13                                  cpu 386
    14                                  
    15                                  bits 16
    16                                  start:
    17 00000000 FA                          cli
    18                                  
    19 00000001 0E                          push cs
    20 00000002 1F                          pop ds
    21                                  
    22 00000003 31C0                        xor ax, ax
    23 00000005 8ED0                        mov ss, ax
    24 00000007 BC007C                      mov sp, 0x7c00
    25                                  
    26 0000000A E83300                      call setup_ivt
    27                                  
    28 0000000D FB                          sti
    29                                  
    30                                      ; test 1: divide by 0 exception (#DE)
    31 0000000E B80100                      mov ax, 1
    32 00000011 31DB                        xor bx, bx
    33 00000013 F7F3                        div bx ; cause #DE
    34                                  
    35                                  test_loop:
    36                                      ; test 2: HW interrupt on INTR
    37                                      ; test 3: HW interrupt on NMI
    38                                      ; test 4: HW interrupt on INTR
    39                                      ;         - nested INTR blocked
    40                                      ;         - RESET to continue
    41                                      ; test 5: divide by 0 exception (#DE)
    42                                      ; test 6: HW interrupt on INTR (sti in ISR)
    43                                      ; test 7: nested INTR allowed
    44                                      ; test 8: HW interrupt on NMI
    45                                      ;         - nested NMI blocked
    46                                      ;         - nested INTR blocked
    47                                      ;         - RESET to continue
    48                                      ; test 9: divide by 0 exception (#DE)
    49                                      ;         - nested INTR blocked
    50                                      ;         - NMI to continue
    51                                      ; test 10: HW interrupt on INTR
    52                                      ; test 11: nested #DE allowed
    53                                      ; test 12: HW interrupt on NMI
    54                                      ; test 13: nested #DE allowed
    55 00000015 FE06[D100]                  inc byte [test_number]
    56 00000019 F4                          hlt
    57 0000001A EBF9                        jmp test_loop
    58                                  
    59                                  intr_test4:
    60                                  nmi_test8:
    61 0000001C E8AA00                      call write_test_number
    62 0000001F F4                          hlt ; wait for nested INTR
    63                                      ; not reached due to RESET
    64                                  
    65                                  intr_test6:
    66 00000020 E8A600                      call write_test_number
    67 00000023 FE06[D100]                  inc byte [test_number]
    68 00000027 FB                          sti
    69 00000028 F4                          hlt ; wait for nested INTR
    70 00000029 CF                          iret
    71                                  
    72                                  div0_test9:
    73 0000002A E89C00                      call write_test_number
    74 0000002D 666783042402                add dword [esp], 2 ; adjust EIP
    75 00000033 F4                          hlt ; wait for nested interrupts
    76 00000034 CF                          iret
    77                                  
    78                                  intr_test10:
    79                                  nmi_test12:
    80 00000035 E89100                      call write_test_number
    81 00000038 B80100                      mov ax, 1
    82 0000003B 31DB                        xor bx, bx
    83 0000003D F7F3                        div bx ; cause #DE
    84 0000003F CF                          iret
    85                                  
    86                                  setup_ivt:
    87 00000040 31C0                        xor ax, ax
    88 00000042 8EC0                        mov es, ax
    89                                  
    90                                      ; vector 0: divide error (#DE)
    91 00000044 26C7060000[7500]            mov word [es:0x00], div0_dispatcher
    92 0000004B 268C0E0200                  mov word [es:0x02], cs
    93                                  
    94                                      ; vector 2: hardware NMI
    95 00000050 26C7060800[8A00]            mov word [es:0x08], nmi_dispatcher
    96 00000057 268C0E0A00                  mov word [es:0x0A], cs
    97                                  
    98                                      ; vector 8: double fault (#DF)
    99 0000005C 26C7062000[9C00]            mov word [es:0x20], double_fault_dispatcher
   100 00000063 268C0E2200                  mov word [es:0x22], cs
   101                                  
   102                                      ; vector 32: hardware INTR
   103 00000068 26C7068000[AA00]            mov word [es:0x80], intr_dispatcher
   104 0000006F 268C0E8200                  mov word [es:0x82], cs
   105                                  
   106 00000074 C3                          ret
   107                                  
   108                                  ; #DE ISR (vector 0)
   109                                  div0_dispatcher:
   110 00000075 FE06[D100]                  inc byte [test_number]
   111 00000079 803E[D100]09                cmp byte [test_number], 9
   112 0000007E 74AA                        je div0_test9
   113                                      ; fallthrough
   114 00000080 E84600                      call write_test_number
   115 00000083 666783042402                add dword [esp], 2 ; adjust EIP
   116 00000089 CF                          iret ; tests 1, 5, 11, 13
   117                                  
   118                                  ; NMI ISR (vector 2)
   119                                  nmi_dispatcher:
   120 0000008A 803E[D100]08                cmp byte [test_number], 8
   121 0000008F 748B                        je nmi_test8
   122 00000091 803E[D100]0C                cmp byte [test_number], 12
   123 00000096 749D                        je nmi_test12
   124                                      ; fallthrough
   125 00000098 E82E00                      call write_test_number
   126 0000009B CF                          iret ; test 3, 9
   127                                  
   128                                  ; #DF ISR (vector 8)
   129                                  double_fault_dispatcher:
   130 0000009C FE06[D100]                  inc byte [test_number]
   131 000000A0 E82600                      call write_test_number
   132 000000A3 B80100                      mov ax, 1
   133 000000A6 31DB                        xor bx, bx
   134 000000A8 F7F3                        div bx ; cause triple fault
   135                                      ; not reached
   136                                  
   137                                  ; INTR ISR (vector 32)
   138                                  intr_dispatcher:
   139 000000AA 803E[D100]04                cmp byte [test_number], 4
   140 000000AF 0F8469FF                    je intr_test4
   141 000000B3 803E[D100]06                cmp byte [test_number], 6
   142 000000B8 0F8464FF                    je intr_test6
   143 000000BC 803E[D100]0A                cmp byte [test_number], 10
   144 000000C1 0F8470FF                    je intr_test10
   145                                      ; fallthrough
   146 000000C5 E80100                      call write_test_number
   147 000000C8 CF                          iret ; test 2, 7, 9
   148                                  
   149                                  write_test_number:
   150 000000C9 50                          push ax
   151 000000CA A0[D100]                    mov al, [test_number]
   152 000000CD E62A                        out DEBUG_PORT, al
   153 000000CF 58                          pop ax
   154 000000D0 C3                          ret
   155                                  
   156 000000D1 00                      test_number db 0
   157                                  
   158 000000D2 90<rep FF1Eh>           times 0xfff0-($-$$) nop
   159                                  
   160                                  bootstrap:
   161 0000FFF0 EA[0000]00F0                jmp C_SEG_REAL:start ; implicitly loads CS with C_SEG_REAL
   162                                  
   163 0000FFF5 90<rep Bh>              times 0x10000-($-$$) nop
