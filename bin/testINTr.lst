     1                                  ; Free86/ testINTr - real mode interrupt tests
     2                                  ; - run various INTR/ NMI tests
     3                                  ; - output test number on port 0x2a
     4                                  ;
     5                                  ; - load image at segment 0xf000
     6                                  ;
     7                                  ; compile:
     8                                  ;   nasm -f bin testINTr.asm -l testINTr.lst -o testINTr.bin
     9                                  
    10                                  C_SEG_REAL equ 0xf000
    11                                  DEBUG_PORT equ 0x2a
    12                                  
    13                                  cpu 386
    14                                  
    15                                  bits 16
    16                                  start:
    17 00000000 FA                          cli
    18                                  
    19 00000001 0E                          push cs
    20 00000002 1F                          pop ds
    21                                  
    22 00000003 31C0                        xor ax, ax
    23 00000005 8ED0                        mov ss, ax
    24 00000007 BC007C                      mov sp, 0x7c00
    25                                  
    26 0000000A E84600                      call setup_ivt
    27                                  
    28 0000000D FB                          sti
    29                                  
    30                                      ; test 1: divide by 0 exception (#DE)
    31 0000000E B80100                      mov ax, 1
    32 00000011 31DB                        xor bx, bx
    33 00000013 F7F3                        div bx ; cause #DE
    34                                  
    35                                  test_loop:
    36                                      ; test 2: HW interrupt on INTR
    37                                      ; test 3: HW interrupt on NMI
    38                                      ; test 4: HW interrupt on INTR
    39                                      ;         - nested INTR blocked
    40                                      ;         - RESET to continue
    41                                      ; test 5: divide by 0 exception (#DE)
    42                                      ; test 6: HW interrupt on INTR (sti in ISR)
    43                                      ; test 7: nested INTR allowed
    44                                      ; test 8: HW interrupt on NMI
    45                                      ;         - nested NMI blocked
    46                                      ;         - nested INTR blocked
    47                                      ;         - RESET to continue
    48                                      ; test 9: divide by 0 exception (#DE)
    49                                      ;         - nested INTR blocked
    50                                      ;         - NMI to continue
    51                                      ; test 10: HW interrupt on INTR
    52                                      ; test 11: nested #DE allowed
    53                                      ; test 12: HW interrupt on NMI
    54                                      ; test 13: nested #DE allowed
    55 00000015 FE06[ED00]                  inc byte [test_number]
    56 00000019 F4                          hlt
    57 0000001A EBF9                        jmp test_loop
    58                                  
    59                                  intr_test4:
    60 0000001C E8C600                      call write_test_number
    61 0000001F F4                          hlt ; wait for nested INTR
    62                                      ; not reached due to RESET
    63                                  
    64                                  intr_test6:
    65 00000020 E8C200                      call write_test_number
    66 00000023 FE06[ED00]                  inc byte [test_number]
    67 00000027 FB                          sti
    68 00000028 F4                          hlt ; wait for nested INTR
    69 00000029 CF                          iret
    70                                  
    71                                  intr_test7:
    72 0000002A E8B800                      call write_test_number
    73 0000002D CF                          iret
    74                                  
    75                                  nmi_test8:
    76 0000002E E8B400                      call write_test_number
    77 00000031 F4                          hlt ; wait for nested INTR
    78                                      ; not reached due to RESET
    79                                  
    80                                  div0_test9:
    81 00000032 E8B000                      call write_test_number
    82 00000035 666783042402                add dword [esp], 2 ; adjust EIP
    83 0000003B F4                          hlt ; wait for nested interrupts
    84 0000003C CF                          iret
    85                                  
    86                                  intr_test10:
    87 0000003D E8A500                      call write_test_number
    88 00000040 B80100                      mov ax, 1
    89 00000043 31DB                        xor bx, bx
    90 00000045 F7F3                        div bx ; cause #DE
    91 00000047 CF                          iret
    92                                  
    93                                  nmi_test12:
    94 00000048 E89A00                      call write_test_number
    95 0000004B B80100                      mov ax, 1
    96 0000004E 31DB                        xor bx, bx
    97 00000050 F7F3                        div bx ; cause #DE
    98 00000052 CF                          iret
    99                                  
   100                                  setup_ivt:
   101 00000053 31C0                        xor ax, ax
   102 00000055 8EC0                        mov es, ax
   103                                  
   104                                      ; vector 0: divide error (#DE)
   105 00000057 26C7060000[8800]            mov word [es:0x00], div0_dispatcher
   106 0000005E 268C0E0200                  mov word [es:0x02], cs
   107                                  
   108                                      ; vector 2: hardware NMI
   109 00000063 26C7060800[9D00]            mov word [es:0x08], nmi_dispatcher
   110 0000006A 268C0E0A00                  mov word [es:0x0A], cs
   111                                  
   112                                      ; vector 8: double fault (#DF)
   113 0000006F 26C7062000[AF00]            mov word [es:0x20], double_fault_dispatcher
   114 00000076 268C0E2200                  mov word [es:0x22], cs
   115                                  
   116                                      ; vector 32: hardware INTR
   117 0000007B 26C7068000[BD00]            mov word [es:0x80], intr_dispatcher
   118 00000082 268C0E8200                  mov word [es:0x82], cs
   119                                  
   120 00000087 C3                          ret
   121                                  
   122                                  ; #DE ISR (vector 0)
   123                                  div0_dispatcher:
   124 00000088 FE06[ED00]                  inc byte [test_number]
   125 0000008C 803E[ED00]09                cmp byte [test_number], 9
   126 00000091 749F                        je div0_test9
   127                                      ; fallthrough
   128 00000093 E84F00                      call write_test_number
   129 00000096 666783042402                add dword [esp], 2 ; adjust EIP
   130 0000009C CF                          iret ; tests 1, 5, 11, 13
   131                                  
   132                                  ; NMI ISR (vector 2)
   133                                  nmi_dispatcher:
   134 0000009D 803E[ED00]08                cmp byte [test_number], 8
   135 000000A2 748A                        je nmi_test8
   136 000000A4 803E[ED00]0C                cmp byte [test_number], 12
   137 000000A9 749D                        je nmi_test12
   138                                      ; fallthrough
   139 000000AB E83700                      call write_test_number
   140 000000AE CF                          iret ; test 3, 9
   141                                  
   142                                  ; #DF ISR (vector 8)
   143                                  double_fault_dispatcher:
   144 000000AF FE06[ED00]                  inc byte [test_number]
   145 000000B3 E82F00                      call write_test_number
   146 000000B6 B80100                      mov ax, 1
   147 000000B9 31DB                        xor bx, bx
   148 000000BB F7F3                        div bx ; cause triple fault
   149                                      ; not reached
   150                                  
   151                                  ; INTR ISR (vector 32)
   152                                  intr_dispatcher:
   153 000000BD 803E[ED00]04                cmp byte [test_number], 4
   154 000000C2 0F8456FF                    je intr_test4
   155 000000C6 803E[ED00]06                cmp byte [test_number], 6
   156 000000CB 0F8451FF                    je intr_test6
   157 000000CF 803E[ED00]07                cmp byte [test_number], 7
   158 000000D4 0F8452FF                    je intr_test7
   159 000000D8 803E[ED00]0A                cmp byte [test_number], 10
   160 000000DD 0F845CFF                    je intr_test10
   161                                      ; fallthrough
   162 000000E1 E80100                      call write_test_number
   163 000000E4 CF                          iret ; test 2
   164                                  
   165                                  write_test_number:
   166 000000E5 50                          push ax
   167 000000E6 A0[ED00]                    mov al, [test_number]
   168 000000E9 E62A                        out DEBUG_PORT, al
   169 000000EB 58                          pop ax
   170 000000EC C3                          ret
   171                                  
   172 000000ED 00                      test_number db 0
   173                                  
   174 000000EE 90<rep FF02h>           times 0xfff0-($-$$) nop
   175                                  
   176                                  bootstrap:
   177 0000FFF0 EA[0000]00F0                jmp C_SEG_REAL:start ; implicitly loads CS with C_SEG_REAL
   178                                  
   179 0000FFF5 90<rep Bh>              times 0x10000-($-$$) nop
