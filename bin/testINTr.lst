     1                                  ; Free86/ testINTr - real mode interrupt tests
     2                                  ; - run various INTR/ NMI tests
     3                                  ; - output test number on port 0x2a
     4                                  ;
     5                                  ; - load image at segment 0xf000
     6                                  ;
     7                                  ; compile:
     8                                  ;   nasm -f bin testINTr.asm -l testINTr.lst -o testINTr.bin
     9                                  
    10                                  C_SEG_REAL  equ 0xf000
    11                                  DEBUG_PORT  equ 0x2a
    12                                  
    13                                  cpu 386
    14                                  
    15                                  bits 16
    16                                  start:
    17 00000000 FA                          cli
    18                                  
    19 00000001 0E                          push cs
    20 00000002 1F                          pop ds
    21                                  
    22 00000003 31C0                        xor ax, ax
    23 00000005 8EC0                        mov es, ax
    24 00000007 8ED0                        mov ss, ax
    25 00000009 BC007C                      mov sp, 0x7c00
    26                                  
    27                                      ; prepare to HLT after reset on triple fault
    28 0000000C C606[F0FF]F4                mov byte [bootstrap], 0xf4
    29                                  
    30 00000011 E83900                      call setup_ivt
    31                                  
    32 00000014 FB                          sti
    33                                  
    34                                      ; test 1: hardware interrupt on INTR
    35 00000015 F4                          hlt                         ; wait for INTR
    36                                  
    37                                      ; test 2: hardware interrupt on NMI
    38 00000016 F4                          hlt                         ; wait for NMI
    39                                  
    40                                      ; test 3: divide by 0 exception (#DE)
    41 00000017 B80100                      mov ax, 1
    42 0000001A 31DB                        xor bx, bx
    43 0000001C F7F3                        div bx                      ; #DE
    44                                  
    45                                      ; test 4: nested INTR allowed (sti)
    46 0000001E F4                          hlt                         ; wait for INTR
    47                                  
    48                                  intr_handler:
    49 0000001F FB                          sti
    50 00000020 F4                          hlt                         ; wait for nested INTR
    51 00000021 CF                          iret
    52                                  
    53                                      ; test 5: Im INTR-Handler CLI + weiteren INTR
    54                                  intr_handler_cli:
    55 00000022 E8B400                      call write_test_number      ; Test 5
    56 00000025 FA                          cli
    57                                      ; User triggert jetzt INTR → sollte **nicht** ausgeführt werden (CLI)
    58                                      ; Danach STI + IRET im nächsten Handler
    59 00000026 CF                          iret
    60                                  
    61                                  ; ------------------------------------------------
    62                                  ; Test 6: Im NMI-Handler weiteren NMI
    63                                  nmi_handler:
    64 00000027 E8AF00                      call write_test_number      ; Test 6
    65                                      ; User triggert **erneut** NMI
    66 0000002A CF                          iret
    67                                  
    68                                  ; ------------------------------------------------
    69                                  ; Test 7: Im INTR-Handler NMI auslösen
    70                                  intr_handler_nmi:
    71 0000002B E8AB00                      call write_test_number      ; Test 7
    72                                      ; User triggert NMI
    73 0000002E CF                          iret
    74                                  
    75                                  ; ------------------------------------------------
    76                                  ; Test 8: Im INTR-Handler Exception
    77                                  intr_handler_exception:
    78 0000002F E8A700                      call write_test_number      ; Test 8
    79 00000032 B80100                      mov ax, 1
    80 00000035 31DB                        xor bx, bx
    81 00000037 F7F3                        div bx                      ; Exception im Handler
    82 00000039 CF                          iret
    83                                  
    84                                  ; ------------------------------------------------
    85                                  ; Test 9: Im NMI-Handler Exception
    86                                  nmi_handler_exception:
    87 0000003A E89C00                      call write_test_number      ; Test 9
    88 0000003D B80100                      mov ax, 1
    89 00000040 31DB                        xor bx, bx
    90 00000042 F7F3                        div bx
    91 00000044 CF                          iret
    92                                  
    93                                  ; ------------------------------------------------
    94                                  ; Test 10: Double Fault
    95                                  double_fault_test:
    96 00000045 E89100                      call write_test_number      ; Test 10
    97                                      ; Wir lösen eine Exception aus, deren Handler wieder eine Exception auslöst
    98 00000048 CD00                        int 0                       ; #DE, dessen Handler wieder #DE macht
    99                                      ; Sollte Double Fault (#DF, Vektor 8) auslösen
   100                                  
   101                                  ; ------------------------------------------------
   102                                  ; Test 11: Triple Fault (sehr schwer zu kontrollieren)
   103                                  triple_fault_test:
   104 0000004A E88C00                      call write_test_number      ; Test 11
   105                                      ; Triple Fault entsteht bei Double Fault im Double-Fault-Handler
   106                                      ; In vielen Emulatoren führt das zum Reset
   107                                  
   108                                  ; ================================================================
   109                                  ; Handler Setup (Real Mode IVT)
   110                                  ; ================================================================
   111                                  setup_ivt:
   112 0000004D 31C0                        xor ax, ax
   113 0000004F 8EC0                        mov es, ax
   114                                  
   115                                      ; Vektor 0: Divide Error (#DE)
   116 00000051 26C7060000[B900]            mov word [es:0x00], div0_handler
   117 00000058 268C0E0200                  mov word [es:0x02], cs
   118                                  
   119                                      ; Vektor 2: NMI
   120 0000005D 26C7060800[A500]            mov word [es:0x08], nmi_handler_main
   121 00000064 268C0E0A00                  mov word [es:0x0A], cs
   122                                  
   123                                      ; Hardware INTR (angenommen Vektor 0x20)
   124 00000069 26C7068000[8200]            mov word [es:0x80], intr_handler_main
   125 00000070 268C0E8200                  mov word [es:0x82], cs
   126                                  
   127                                      ; Double Fault (Vektor 8)
   128 00000075 26C7062000[D300]            mov word [es:0x20], double_fault_handler
   129 0000007C 268C0E2200                  mov word [es:0x22], cs
   130                                  
   131 00000081 C3                          ret
   132                                  
   133                                  ; ================================================================
   134                                  ; Haupt-Handler (mit Test-Steuerung)
   135                                  ; ================================================================
   136                                  
   137                                  ; INTR Haupt-Handler
   138                                  intr_handler_main:
   139 00000082 E85400                      call write_test_number
   140 00000085 803E[E500]04                cmp byte [test_num], 4
   141 0000008A 7493                        je intr_handler          ; Test 4
   142 0000008C 803E[E500]05                cmp byte [test_num], 5
   143 00000091 748F                        je intr_handler_cli      ; Test 5
   144 00000093 803E[E500]07                cmp byte [test_num], 7
   145 00000098 7491                        je intr_handler_nmi      ; Test 7
   146 0000009A 803E[E500]08                cmp byte [test_num], 8
   147 0000009F 748E                        je intr_handler_exception; Test 8
   148                                  
   149                                      ; Normaler Fall (Test 1)
   150 000000A1 E83500                      call write_test_number
   151 000000A4 CF                          iret
   152                                  
   153                                  ; NMI Haupt-Handler
   154                                  nmi_handler_main:
   155 000000A5 803E[E500]06                cmp byte [test_num], 6
   156 000000AA 0F8479FF                    je nmi_handler           ; Test 6
   157 000000AE 803E[E500]09                cmp byte [test_num], 9
   158 000000B3 7485                        je nmi_handler_exception ; Test 9
   159                                  
   160 000000B5 E82100                      call write_test_number   ; Test 2
   161 000000B8 CF                          iret
   162                                  
   163                                  ; Divide by Zero Handler
   164                                  div0_handler:
   165 000000B9 803E[E500]03                cmp byte [test_num], 3
   166 000000BE 7409                        je .normal_exception
   167 000000C0 803E[E500]0A                cmp byte [test_num], 10
   168 000000C5 0F847CFF                    je double_fault_test
   169                                  
   170                                  .normal_exception:
   171 000000C9 E80D00                      call write_test_number
   172 000000CC 666783042402                add dword [esp], 2       ; adjust EIP
   173 000000D2 CF                          iret
   174                                  
   175                                  ; Double Fault Handler
   176                                  double_fault_handler:
   177 000000D3 E80300                      call write_test_number   ; Test 10 (Double Fault)
   178                                      ; Für Triple Fault: hier wieder Exception auslösen
   179 000000D6 CD00                        int 0
   180 000000D8 CF                          iret                     ; Sollte nie ankommen
   181                                  
   182                                  ; ================================================================
   183                                  ; Hilfsroutine: Testnummer auf Port 0x2A schreiben
   184                                  ; ================================================================
   185                                  write_test_number:
   186 000000D9 50                          push ax
   187 000000DA FE06[E500]                  inc byte [test_num]
   188 000000DE A0[E500]                    mov al, [test_num]
   189 000000E1 E62A                        out DEBUG_PORT, al
   190 000000E3 58                          pop ax
   191 000000E4 C3                          ret
   192                                  
   193 000000E5 00                      test_num db 0
   194                                  
   195 000000E6 90<rep FF0Ah>           times 0xfff0-($-$$) nop
   196                                  
   197                                  bootstrap:
   198 0000FFF0 EA[0000]00F0                jmp   C_SEG_REAL:start ; implicitly loads CS with C_SEG_REAL
   199                                  
   200 0000FFF5 90<rep Bh>              times 0x10000-($-$$) nop
