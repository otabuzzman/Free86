     1                                  ; Free86/ testINTr - real mode interrupt tests
     2                                  ; - run various INTR/ NMI tests
     3                                  ; - output test number on port 0x2a
     4                                  ;
     5                                  ; - load image at segment 0xf000
     6                                  ;
     7                                  ; compile:
     8                                  ;   nasm -f bin testINTr.asm -l testINTr.lst -o testINTr.bin
     9                                  
    10                                  C_SEG_REAL equ 0xf000
    11                                  DEBUG_PORT equ 0x2a
    12                                  
    13                                  cpu 386
    14                                  
    15                                  bits 16
    16                                  start:
    17 00000000 FA                          cli
    18                                  
    19 00000001 0E                          push cs
    20 00000002 1F                          pop ds
    21                                  
    22 00000003 31C0                        xor ax, ax
    23 00000005 8ED0                        mov ss, ax
    24 00000007 BC007C                      mov sp, 0x7c00
    25                                  
    26 0000000A E85A00                      call setup_ivt
    27                                  
    28 0000000D FB                          sti
    29                                  
    30                                      ; test 1: divide by 0 exception (#DE)
    31 0000000E B80100                      mov ax, 1
    32 00000011 31DB                        xor bx, bx
    33 00000013 F7F3                        div bx ; cause #DE
    34                                  
    35                                  test_loop:
    36                                      ; test 2: HW interrupt on INTR
    37                                      ; test 3: HW interrupt on NMI
    38                                      ; test 4: HW interrupt on INTR
    39                                      ;         - nested INTR blocked
    40                                      ;         - RESET to continue
    41                                      ; test 5: divide by 0 exception (#DE)
    42                                      ; test 6: HW interrupt on INTR (sti in ISR)
    43                                      ; test 7: nested INTR allowed
    44                                      ; test 8: HW interrupt on NMI
    45                                      ;         - nested NMI blocked
    46                                      ;         - nested INTR blocked
    47                                      ;         - RESET to continue
    48                                      ; test 9: divide by 0 exception (#DE)
    49                                      ;         - nested NMI blocked
    50                                      ;         - nested INTR blocked
    51                                      ;         - RESET to continue
    52                                      ; test 10: divide by 0 exception (#DE)
    53                                      ; test 11: HW interrupt on INTR
    54                                      ; test 12: nested #DE in INTR ISR
    55                                      ; test 13: HW interrupt on NMI
    56                                      ; test 14: nested #DE in NMI ISR
    57                                      ; test 15: nested #DE in #DE ISR (double fault)
    58                                      ; test 16: triple fault
    59 00000015 FE06[1101]                  inc byte [test_number]
    60 00000019 F4                          hlt
    61 0000001A EBF9                        jmp test_loop
    62                                  
    63                                  intr_test4:
    64 0000001C E8EA00                      call write_test_number
    65 0000001F F4                          hlt ; wait for nested INTR
    66                                      ; not reached due to RESET
    67                                  
    68                                  intr_test6:
    69 00000020 E8E600                      call write_test_number
    70 00000023 FE06[1101]                  inc byte [test_number]
    71 00000027 FB                          sti
    72 00000028 F4                          hlt ; wait for nested INTR
    73 00000029 CF                          iret
    74                                  
    75                                  intr_test7:
    76 0000002A E8DC00                      call write_test_number
    77 0000002D CF                          iret
    78                                  
    79                                  nmi_test8:
    80 0000002E E8D800                      call write_test_number
    81 00000031 F4                          hlt ; wait for nested INTR
    82                                      ; not reached due to RESET
    83                                  
    84                                  div0_test9:
    85 00000032 E8D400                      call write_test_number
    86 00000035 666783042402                add dword [esp], 2 ; adjust EIP
    87 0000003B F4                          hlt ; wait for nested interrupts
    88 0000003C CF                          iret
    89                                  
    90                                  intr_test11:
    91 0000003D E8C900                      call write_test_number
    92 00000040 B80100                      mov ax, 1
    93 00000043 31DB                        xor bx, bx
    94 00000045 F7F3                        div bx ; cause #DE
    95 00000047 CF                          iret
    96                                  
    97                                  div0_test12:
    98 00000048 E8BE00                      call write_test_number
    99 0000004B 666783042402                add dword [esp], 2 ; adjust EIP
   100 00000051 CF                          iret
   101                                  
   102                                  nmi_test13:
   103 00000052 E8B400                      call write_test_number
   104 00000055 B80100                      mov ax, 1
   105 00000058 31DB                        xor bx, bx
   106 0000005A F7F3                        div bx ; cause #DE
   107 0000005C CF                          iret
   108                                  
   109                                  div0_test14:
   110 0000005D E8A900                      call write_test_number
   111 00000060 B80100                      mov ax, 1
   112 00000063 31DB                        xor bx, bx
   113 00000065 F7F3                        div bx ; cause #DE
   114                                      ; not reached
   115                                  
   116                                  setup_ivt:
   117 00000067 31C0                        xor ax, ax
   118 00000069 8EC0                        mov es, ax
   119                                  
   120                                      ; vector 0: divide error (#DE)
   121 0000006B 26C7060000[9C00]            mov word [es:0x00], div0_dispatcher
   122 00000072 268C0E0200                  mov word [es:0x02], cs
   123                                  
   124                                      ; vector 2: hardware NMI
   125 00000077 26C7060800[BF00]            mov word [es:0x08], nmi_dispatcher
   126 0000007E 268C0E0A00                  mov word [es:0x0A], cs
   127                                  
   128                                      ; vector 8: double fault (#DF)
   129 00000083 26C7062000[D300]            mov word [es:0x20], double_fault_dispatcher
   130 0000008A 268C0E2200                  mov word [es:0x22], cs
   131                                  
   132                                      ; vector 32: hardware INTR
   133 0000008F 26C7068000[E100]            mov word [es:0x80], intr_dispatcher
   134 00000096 268C0E8200                  mov word [es:0x82], cs
   135                                  
   136 0000009B C3                          ret
   137                                  
   138                                  ; #DE ISR (vector 0)
   139                                  div0_dispatcher:
   140 0000009C FE06[1101]                  inc byte [test_number]
   141 000000A0 803E[1101]09                cmp byte [test_number], 9
   142 000000A5 748B                        je div0_test9
   143 000000A7 803E[1101]0C                cmp byte [test_number], 12
   144 000000AC 749A                        je div0_test12
   145 000000AE 803E[1101]0E                cmp byte [test_number], 14
   146 000000B3 74A8                        je div0_test14
   147                                      ; fallthrough
   148 000000B5 E85100                      call write_test_number
   149 000000B8 666783042402                add dword [esp], 2 ; adjust EIP
   150 000000BE CF                          iret ; tests 1, 5
   151                                  
   152                                  ; NMI ISR (vector 2)
   153                                  nmi_dispatcher:
   154 000000BF 803E[1101]08                cmp byte [test_number], 8
   155 000000C4 0F8466FF                    je nmi_test8
   156 000000C8 803E[1101]0D                cmp byte [test_number], 13
   157 000000CD 7483                        je nmi_test13
   158                                      ; fallthrough
   159 000000CF E83700                      call write_test_number
   160 000000D2 CF                          iret ; test 3
   161                                  
   162                                  ; #DF ISR (vector 8)
   163                                  double_fault_dispatcher:
   164 000000D3 FE06[1101]                  inc byte [test_number]
   165 000000D7 E82F00                      call write_test_number
   166 000000DA B80100                      mov ax, 1
   167 000000DD 31DB                        xor bx, bx
   168 000000DF F7F3                        div bx ; cause triple fault
   169                                      ; not reached
   170                                  
   171                                  ; INTR ISR (vector 32)
   172                                  intr_dispatcher:
   173 000000E1 803E[1101]04                cmp byte [test_number], 4
   174 000000E6 0F8432FF                    je intr_test4
   175 000000EA 803E[1101]06                cmp byte [test_number], 6
   176 000000EF 0F842DFF                    je intr_test6
   177 000000F3 803E[1101]07                cmp byte [test_number], 7
   178 000000F8 0F842EFF                    je intr_test7
   179 000000FC 803E[1101]0B                cmp byte [test_number], 11
   180 00000101 0F8438FF                    je intr_test11
   181                                      ; fallthrough
   182 00000105 E80100                      call write_test_number
   183 00000108 CF                          iret ; test 2
   184                                  
   185                                  write_test_number:
   186 00000109 50                          push ax
   187 0000010A A0[1101]                    mov al, [test_number]
   188 0000010D E62A                        out DEBUG_PORT, al
   189 0000010F 58                          pop ax
   190 00000110 C3                          ret
   191                                  
   192 00000111 00                      test_number db 0
   193                                  
   194 00000112 90<rep FEDEh>           times 0xfff0-($-$$) nop
   195                                  
   196                                  bootstrap:
   197 0000FFF0 EA[0000]00F0                jmp C_SEG_REAL:start ; implicitly loads CS with C_SEG_REAL
   198                                  
   199 0000FFF5 90<rep Bh>              times 0x10000-($-$$) nop
