     1                                  ; Free86/ testINTs - simple interrupt test program
     2                                  ; - wait in loop for INT/ NMI
     3                                  ; - output vector on port 0x2a
     4                                  ;
     5                                  ; - load image at segment 0xf000
     6                                  ;
     7                                  ; compile:
     8                                  ;   nasm -f bin testINTs.asm -l testINTs.lst -o testINTs.bin
     9                                  
    10                                  C_SEG_REAL  equ 0xf000
    11                                  DEBUG_PORT  equ 0x2a
    12                                  
    13                                  cpu 386
    14                                  
    15                                  bits 16
    16                                  start:
    17 00000000 FA                          cli
    18 00000001 FC                          cld
    19                                  
    20                                      ; set stack
    21 00000002 31C0                        xor ax, ax
    22 00000004 8ED0                        mov ss, ax
    23 00000006 BC007C                      mov sp, 0x7c00
    24                                  
    25                                      ; set data to point at code segment
    26 00000009 0E                          push cs
    27 0000000A 1F                          pop ds
    28                                  
    29                                      ; set ES (stosw) to point at physical address 0
    30 0000000B 31C0                        xor ax, ax
    31 0000000D 8EC0                        mov es, ax
    32                                  
    33                                      ; copy IVT to physical address 0
    34 0000000F 31FF                        xor di, di          ; destination ES:di (stosw)
    35 00000011 BE[2D00]                    mov si, ivt         ; source DS:si (lodsw)
    36 00000014 B90001                      mov cx, 256
    37                                  
    38                                  .copy_ivt:
    39 00000017 AD                          lodsw
    40 00000018 AB                          stosw
    41 00000019 8CC8                        mov ax, cs
    42 0000001B AB                          stosw
    43 0000001C E2F9                        loop .copy_ivt
    44                                  
    45 0000001E 0F011E[2700]                lidt [idtr]
    46                                  
    47 00000023 FB                          sti
    48                                  
    49                                  .loop:
    50 00000024 90                          nop                 ; wait for next INT/ NMI
    51 00000025 EBFD                        jmp .loop
    52                                  
    53                                  idtr:
    54 00000027 FF03                        dw 0x03ff
    55 00000029 00000000                    dd 0x00000000
    56                                  
    57                                  ; ------------------------------------------------------------
    58                                  ; offset table for 256 interrupt service routines (ISR)
    59                                  ; ------------------------------------------------------------
    60                                  
    61                                  ivt:
    62                                  %assign i 0
    63                                  %rep 256
    64                                      dw isr%+i
    65                                  %assign i i+1
    66                                  %endrep
