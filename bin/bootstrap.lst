     1                                  ;----------------------------------------------------------------------
     2                                  ; bootstrap.asm - setup 386 emulator for linuxstart.bin execution
     3                                  ;
     4                                  ; compile:
     5                                  ;     nasm -f bin -o bootstrap.bin -l bootstrap.lst bootstrap.asm
     6                                  ;
     7                                  ; linuxstart.bin expects a specific CPU state. The original code
     8                                  ; sets this state by writing values directly to the corresponding
     9                                  ; registers.
    10                                  ;
    11                                  ; This state can also be set by a program (like this one) that starts
    12                                  ; directly from the CPU reset state, in real mode, at address 0xffff0.
    13                                  ;----------------------------------------------------------------------
    14                                  
    15                                  C_SEG_REAL equ 0xf000
    16                                  C_SEG_PROT equ 0x08
    17                                  
    18                                  C_SEG_LINUX equ 0x10
    19                                  D_SEG_LINUX equ 0x18
    20                                  
    21                                  linuxstart equ 0x00010000
    22                                  
    23                                  cpu 386
    24                                  
    25                                  bits 16
    26                                  start:
    27 00000000 FA                          cli ; common practice
    28                                  
    29                                      ; load GDTR
    30 00000001 2E660F0116[5800]            o32 lgdt [cs:GDTR]
    31                                  
    32                                      ; protected mode
    33 00000008 0F20C0                      mov eax, cr0
    34 0000000B 6683C801                    or eax, 1
    35 0000000F 0F22C0                      mov cr0, eax
    36                                  
    37 00000012 EA[1700]0800                jmp C_SEG_PROT:flush ; implicitly loads PM CS with selector 0x08
    38                                                           ; with its base 0xf0000 corresponding to
    39                                                           ; real mode CS and thus asures that PM
    40                                                           ; continues execution in same address space.
    41                                  
    42                                  bits 32
    43                                  flush:
    44                                      ; prepare state
    45 00000017 66B81800                    mov ax, D_SEG_LINUX
    46 0000001B 8ED8                        mov ds, ax
    47 0000001D 8ED0                        mov ss, ax
    48                                  
    49 0000001F B800000001                  mov eax, 16 * 1024 * 1024 ; mem_size
    50 00000024 B900F80000                  mov ecx, 0x0000f800       ; cmdline_addr
    51 00000029 BB00002000                  mov ebx, 2 * 1024 * 1024  ; initrd_size
    52                                  
    53 0000002E EA000001001000              jmp C_SEG_LINUX:linuxstart ; implicitly reloads PM CS with
    54                                                                 ; selector 0x10 with base 0xffff0000,
    55                                                                 ; the value after reset and expected
    56                                                                 ; by linuxstart.bin.
    57                                      ; end of prepare state
    58                                  
    59                                  ;----------------------------------------------------------------------
    60                                  ; Global Descriptor Table (GDT)
    61                                  ;----------------------------------------------------------------------
    62 00000035 90<rep 3h>              align 8
    63                                  GDT_alpha:
    64                                      ; 1st descriptor table entry (dte), selector NULL
    65 00000038 0000000000000000            dq 0
    66                                  
    67                                      ; 2nd dte, CS selector 0x08, base 0x000f0000, 32 bit, executable
    68 00000040 FFFF                        dw 0xFFFF
    69 00000042 0000                        dw 0x0000
    70 00000044 0F                          db 0x0F
    71 00000045 9A                          db 0x9A
    72 00000046 4F                          db 0x4F
    73 00000047 00                          db 0x00
    74                                  
    75                                      ; 3rd dte, CS selector 0x10, base 0xffff0000, 32 bit, executable
    76 00000048 FFFF                        dw 0xFFFF
    77 0000004A 0000                        dw 0x0000
    78 0000004C FF                          db 0xFF
    79 0000004D 9A                          db 0x9A
    80 0000004E 4F                          db 0x4F
    81 0000004F FF                          db 0xFF
    82                                  
    83                                      ; 4th dte, DS selector 0x18, base 0, 32 bit, writable
    84 00000050 FFFF                        dw 0xFFFF
    85 00000052 0000                        dw 0x0000
    86 00000054 00                          db 0x00
    87 00000055 92                          db 0x92
    88 00000056 4F                          db 0x4F
    89 00000057 00                          db 0x00
    90                                  GDT_omega:
    91                                  
    92                                  GDTR:
    93 00000058 1F00                        dw GDT_omega - GDT_alpha - 1   ; limit
    94 0000005A [38000F00]                  dd C_SEG_REAL * 16 + GDT_alpha ; base
    95                                  
    96                                  ; ----------------------------------------------------------------
    97                                  ;   fill-in NOPs until 0xfff0 where execution starts after reset
    98                                  ; ----------------------------------------------------------------
    99 0000005E 90<rep FF92h>           times 0xfff0-($-$$) nop
   100                                  
   101                                  bits 16
   102                                  bootstrap:
   103 0000FFF0 EA[0000]00F0                jmp   C_SEG_REAL:start ; implicitly loads CS with C_SEG_REAL
