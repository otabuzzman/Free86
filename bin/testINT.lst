     1                                  ; Free86/ testINT
     2                                  ; - loop on wait for INT/ NMI
     3                                  ; - output vector number on port 2a
     4                                  ;
     5                                  ; - load 64k image at segment f000
     6                                  ; - interrupt vector at f000:fff0
     7                                  ;
     8                                  ; compile:
     9                                  ;   nasm -f bin testINT.asm -l testINT.lst -o testINT.bin
    10                                  
    11                                  C_SEG_REAL  equ 0xf000
    12                                  DEBUG_PORT  equ 0x2a
    13                                  
    14                                  cpu 386
    15                                  
    16                                  bits 16
    17                                  start:
    18 00000000 FA                          cli
    19                                  
    20                                      ; set stack
    21 00000001 31C0                        xor ax, ax
    22 00000003 8ED0                        mov ss, ax
    23 00000005 BC007C                      mov sp, 0x7c00
    24                                  
    25                                      ; DS = CS for accessing interrupt tables and service routines
    26 00000008 0E                          push cs
    27 00000009 1F                          pop ds
    28                                  
    29                                      ; ES = 0 to have IVT at physical address 0 (ES used by stosw)
    30 0000000A 31C0                        xor ax, ax
    31 0000000C 8EC0                        mov es, ax
    32                                  
    33 0000000E 0F011E[2600]                lidt [idtr]
    34                                  
    35                                      ; fill IVT with 256 ISRs
    36 00000013 31FF                        xor di, di
    37 00000015 BE[2C00]                    mov si, ivt
    38 00000018 B90001                      mov cx, 256
    39                                  
    40                                  .setup_ivt:
    41 0000001B AD                          lodsw
    42 0000001C AB                          stosw
    43 0000001D 8CC8                        mov ax, cs
    44 0000001F AB                          stosw
    45 00000020 E2F9                        loop .setup_ivt
    46                                  
    47 00000022 FB                          sti
    48                                  
    49                                  .loop:
    50 00000023 90                          nop                 ; wait for next INT/ NMI
    51 00000024 EBFD                        jmp .loop
    52                                  
    53                                  idtr:
    54 00000026 FF03                        dw 0x03ff
    55 00000028 00000000                    dd 0x00000000
    56                                  
    57                                  ; ------------------------------------------------------------
    58                                  ; offset table for 256 interrupt service routines (ISR)
    59                                  ; ------------------------------------------------------------
    60                                  
    61                                  ivt:
    62                                  %assign i 0
    63                                  %rep 256
    64                                      dw isr%+i
    65                                  %assign i i+1
    66                                  %endrep
    64 0000002C [2C02]              <1>  dw isr%+i
    65                              <1> %assign i i+1
    64 0000002E [3702]              <1>  dw isr%+i
    65                              <1> %assign i i+1
